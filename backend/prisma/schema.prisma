generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // connection_limit é controlado via query param na DATABASE_URL:
  // ex: ?connection_limit=5&pool_timeout=10
}

model Montador {
  id                 Int                 @id @default(autoincrement())
  nome               String
  telefone           String?             @unique
  senhaHash          String?             @map("password")
  pixChave           String?
  notaMedia          Float?              @default(5.0) @map("rating")
  status             String?             @default("disponivel")
  cpf                String?
  cidade             String?
  lat                Float?
  lng                Float?
  email              String?
  rg                 String?
  nascimento         DateTime?
  cep                String?
  endereco           String?
  estado             String?             @default("GO")
  ipOrigem           String?             @map("ip_origem")
  localizacaoConfirmada Boolean?         @default(false) @map("localizacao_confirmada")
  nivelExperiencia   String?             @map("nivel_experiencia") // simples, medio_complexo, luxo
  anosExperiencia    String?             @map("anos_experiencia")
  cnpjStatus         String?             @map("cnpj_status") // nao, sim
  cnpj               String?
  especialidades     String[]            @default([])
  ferramentas        String?
  referencias        String?
  disponibilidade    String?
  origem             String?
  observacaoRejeicao String?             @map("observacao_rejeicao")
  codigoVerificacao String?             @map("codigo_verificacao")
  
  
  docRg              String?             @db.Text @map("doc_rg")
  docCpf             String?             @db.Text @map("doc_cpf")
  docComprovante     String?             @db.Text @map("doc_comprovante")
  docFoto            String?             @db.Text @map("doc_foto")
  docAntecedente     String?             @map("doc_antecedente")
  docPortfolio       String[]            @default([]) @map("doc_portfolio")
  
  role               String              @default("montador")
  fotoUrl            String?             @map("foto_url")
  emailVerificado    Boolean             @default(false)
  aprovadoEm         DateTime?           @map("aprovado_em")
  createdAt          DateTime?           @default(now())
  updatedAt          DateTime?           @updatedAt

  refreshTokens      RefreshToken[]
  pushSubscriptions  PushSubscription[]
  ordens             OrdemServico[]
  convites           Convite[]
  execucoes          Execucao[]
  avaliacoes         Avaliacao[]

  @@map("montador")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  montadorId Int
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  montador   Montador  @relation(fields: [montadorId], references: [id], onDelete: Cascade)

  @@index([montadorId])
  @@map("refresh_tokens")
}

model PushSubscription {
  id         Int       @id @default(autoincrement())
  endpoint   String    @unique
  p256dh     String
  auth       String
  montadorId Int
  createdAt  DateTime  @default(now())

  montador   Montador  @relation(fields: [montadorId], references: [id], onDelete: Cascade)

  @@index([montadorId])
  @@map("push_subscriptions")
}

model Cliente {
  id        Int       @id @default(autoincrement())
  nome      String
  telefone  String
  email     String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  ordens    OrdemServico[]

  @@map("clientes")
}

model OrdemServico {
  id             Int         @id @default(autoincrement())
  numero         String?     @unique
  descricao      String
  clienteNome    String?     @map("cliente_nome")
  clienteContato String?     @map("cliente_contato")
  cidade         String?
  estado         String?
  tipoProjeto    String?     @map("tipo_projeto")
  observacoes    String?
  endereco       String
  lat            Float
  lng            Float
  valorBruto     Float
  status         String?     @default("pendente")
  dataInstalacao DateTime
  clienteId      Int
  montadorId     Int?
  createdAt      DateTime?   @default(now())
  updatedAt      DateTime?   @updatedAt

  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  montador       Montador?   @relation(fields: [montadorId], references: [id])

  convites       Convite[]
  execucoes      Execucao[]
  avaliacoes     Avaliacao[]

  @@index([clienteId])
  @@index([montadorId])
  @@map("ordens_servico")
}

model Convite {
  id           Int          @id @default(autoincrement())
  ordemId      Int
  montadorId   Int
  status       String?      @default("pendente")
  expiresAt    DateTime
  respondidoAt DateTime?
  createdAt    DateTime?    @default(now())

  ordem        OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  montador     Montador     @relation(fields: [montadorId], references: [id], onDelete: Cascade)

  @@index([ordemId])
  @@index([montadorId])
  @@map("convites")
}

model Execucao {
  id          Int          @id @default(autoincrement())
  ordemId     Int
  montadorId  Int
  status      String?      @default("em_andamento")
  chegadaAt   DateTime?
  latChegada  Float?
  lngChegada  Float?
  conclusaoAt DateTime?
  createdAt   DateTime?    @default(now())

  ordem       OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  montador    Montador     @relation(fields: [montadorId], references: [id], onDelete: Cascade)

  fotos       Foto[]

  @@index([ordemId])
  @@index([montadorId])
  @@map("execucoes")
}

model Foto {
  id          Int      @id @default(autoincrement())
  execucaoId  Int
  url         String
  tipo        String
  createdAt   DateTime? @default(now())

  execucao    Execucao @relation(fields: [execucaoId], references: [id], onDelete: Cascade)

  @@index([execucaoId])
  @@map("fotos")
}

model Avaliacao {
  id          Int          @id @default(autoincrement())
  ordemId     Int
  montadorId  Int
  nota        Float
  comentario  String?
  createdAt   DateTime?    @default(now())

  ordem       OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  montador    Montador     @relation(fields: [montadorId], references: [id], onDelete: Cascade)

  @@index([ordemId])
  @@index([montadorId])
  @@map("avaliacoes")
}